# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=notebot

# ── Optional ──────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with admin access (e.g. /stats command)
ADMIN_IDS=123456789

# ── Production webhook (leave empty for local polling) ────────────────────────
WEBHOOK_URL=https://your-app.vercel.app

# ── Server (used when running locally with uvicorn) ───────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
