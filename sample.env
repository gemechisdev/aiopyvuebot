# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=notebot

# ── Web App ───────────────────────────────────────────────────────────────────
# Full URL where the Mini App is hosted (required for the WebApp button)
WEB_APP_URL=https://your-app.vercel.app
# Also exposed to the Vite frontend (shows "Back to Bot" button)
VITE_TELEGRAM_BOT_LINK=https://t.me/your_bot_username

# ── Optional ──────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with admin access (e.g. /stats command)
ADMIN_IDS=123456789

# ── Production webhook ────────────────────────────────────────────────────────
# Set WEBHOOK_URL to enable auto-registration on startup (Vercel / any HTTPS host)
WEBHOOK_URL=https://your-app.vercel.app

# ── Server (local uvicorn) ────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
